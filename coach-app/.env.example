# Hockey ID Coach App — API config
# Canonical backend: Next.js CRM.
# Local: http://localhost:3000 (simulator only).
# Physical device: use your machine IP, e.g. http://192.168.1.10:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Demo mode: local login without backend. coach@hockey.edu / admin123 works offline.
# Set to true for local/dev without server.
EXPO_PUBLIC_DEMO_MODE=true

# Environment: set to production for live deploy. Coach API then requires Bearer token only.
# EXPO_PUBLIC_ENV=production

# Optional: request timeout in ms
# EXPO_PUBLIC_API_TIMEOUT_MS=10000
