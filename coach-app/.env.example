# Hockey ID Coach App — API config
#
# Один base URL на все запросы (auth, coach, trainings, evaluations, report).
# По умолчанию ниже — локальный Next CRM (:3000). Если в вашем CRM нет
# GET/POST /api/trainings/:id/evaluations и /api/trainings/:id/report,
# задайте URL бэкенда, где они реализованы (часто hockey-server), например:
# EXPO_PUBLIC_API_URL=http://localhost:4000
#
# Симулятор: localhost ок. Физическое устройство: IP машины, напр. http://192.168.1.10:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Demo mode: local login without backend. coach@hockey.edu / admin123 works offline.
# Keep false for release builds. Never enable in public production rollout.
EXPO_PUBLIC_DEMO_MODE=false

# Environment: set to production for live deploy. Coach API then requires Bearer token only.
# EXPO_PUBLIC_ENV=production

# Optional: request timeout in ms
# EXPO_PUBLIC_API_TIMEOUT_MS=10000
