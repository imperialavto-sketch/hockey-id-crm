# Hockey ID Coach App — API config
#
# Один base URL на все запросы (auth, coach, live-training, schedule, …).
# Канон для coach-app — развёрнутый Next CRM (тот же origin, что `npm run dev` в корне репо; совпадает с parent-app EXPO_PUBLIC_API_URL в той же среде).
# Не направляйте coach-app на hockey-server: там нет полного набора coach/live-training маршрутов.
# Другой порт/хост — только если у вас отдельный прокси на тот же Next API, не legacy Express.
#
# Симулятор: localhost ок. Физическое устройство: IP машины, напр. http://192.168.1.10:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Demo mode: local login without backend. coach@hockey.edu / admin123 works offline.
# Keep false for release builds. Never enable in public production rollout.
EXPO_PUBLIC_DEMO_MODE=false

# Environment: set to production for live deploy. Coach API then requires Bearer token only.
# EXPO_PUBLIC_ENV=production

# Optional: request timeout in ms
# EXPO_PUBLIC_API_TIMEOUT_MS=10000
