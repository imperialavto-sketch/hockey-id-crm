# Demo mode: false = live backend, true = demo data only
# Never enable for public production rollout.
EXPO_PUBLIC_DEMO_MODE=false

# API base URL — Next.js CRM (Phase 1). REQUIRED for production build (EAS build).
# Dev: Next.js CRM on same machine. Replace with your Mac's LAN IP for physical device.
# Use the same Next origin as coach-app (repo root `npm run dev`, default :3000). Not hockey-server.
EXPO_PUBLIC_API_URL=http://localhost:3000

# Device-specific URL (optional; falls back to EXPO_PUBLIC_API_URL)
# Uncomment and set to your Mac's LAN IP for physical device: http://192.168.x.x:3000
# EXPO_PUBLIC_DEVICE_API_URL=

# Live integration: false = propagate API errors, true = fallback to demo on failure
# Keep false in production.
EXPO_PUBLIC_ENABLE_API_FALLBACK=false

# Expo project ID for push notifications (from expo.dev project settings)
# Required for EAS Build and push notifications
EXPO_PUBLIC_EXPO_PROJECT_ID=your-project-id
