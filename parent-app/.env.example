# Demo mode: false = live backend, true = demo data only
EXPO_PUBLIC_DEMO_MODE=false

# API base URL — REQUIRED for production build (EAS build)
# Live backend (default when env not set):
EXPO_PUBLIC_API_URL=https://hockey-server-api.onrender.com

# Device-specific URL (optional; falls back to EXPO_PUBLIC_API_URL)
# For local dev against hockey-server: http://192.168.x.x:3000
EXPO_PUBLIC_DEVICE_API_URL=https://hockey-server-api.onrender.com

# Live integration: false = propagate API errors, true = fallback to demo on failure
EXPO_PUBLIC_ENABLE_API_FALLBACK=false

# Expo project ID for push notifications (from expo.dev project settings)
# Required for EAS Build and push notifications
EXPO_PUBLIC_EXPO_PROJECT_ID=your-project-id
