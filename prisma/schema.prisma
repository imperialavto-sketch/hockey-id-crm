generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SCHOOL_ADMIN
  MAIN_COACH
  COACH
  SCHOOL_MANAGER
  PARENT
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole
  schoolId  String?
  phone     String?
  teamId    String?
  status    String   @default("Активен")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school                 School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  team                   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  linkedMarketplaceCoach Coach?  @relation("UserMarketplaceCoach")
}

model UserSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  name                String?
  email               String?
  avatarUrl           String?
  emailNotifications  Boolean  @default(true)
  pushNotifications   Boolean  @default(true)
  smsNotifications    Boolean  @default(false)
  theme               String   @default("dark")
  colorScheme         String   @default("neon")
  googleCalendarSync  Boolean  @default(false)
  paymentSystem       String?
  analyticsService    String?
  twoFactorEnabled    Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model School {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?
  city        String?
  country     String?
  address     String?
  phone       String?
  email       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users  User[]  @relation()
  teams  Team[]
}

model Role {
  id         String   @id @default(cuid())
  name       String
  systemRole String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  permissions Permission[]
}

model Permission {
  id        String   @id @default(cuid())
  roleId    String
  module    String
  canView   Boolean  @default(true)
  canCreate Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  id         String   @id @default(cuid())
  theme      String?  @default("dark")
  language   String?  @default("ru")
  timezone   String?  @default("Europe/Moscow")
  dateFormat String?  @default("DD.MM.YYYY")
  currency   String?  @default("RUB")
  schoolId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model NotificationSetting {
  id               String   @id @default(cuid())
  userId           String?
  schoolId         String?
  emailEnabled     Boolean  @default(true)
  pushEnabled      Boolean  @default(true)
  systemEnabled    Boolean  @default(true)
  newMessages      Boolean  @default(true)
  newPayments      Boolean  @default(true)
  overduePayments  Boolean  @default(true)
  newTrainings     Boolean  @default(true)
  scheduleChanges  Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Team {
  id        String   @id @default(cuid())
  name      String
  ageGroup  String
  schoolId  String
  coachId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school       School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  coach        Coach?         @relation(fields: [coachId], references: [id], onDelete: SetNull)
  trainings    Training[]
  players      Player[]
  users        User[]
  feedPosts    TeamFeedPost[]
  groups       TeamGroup[]
  trainingSessions TrainingSession[]
}

model TeamGroup {
  id        String   @id @default(cuid())
  teamId    String
  name      String   // A, B, C или "Сильные"
  level     Int      @default(1) // 1, 2, 3
  sortOrder Int      @default(0) // для сортировки
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team               Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignments        PlayerGroupAssignment[]
  trainingSessions   TrainingSession[]
}

model PlayerGroupAssignment {
  id                 String   @id @default(cuid())
  playerId           String
  groupId            String
  weekStartDate      DateTime // Monday 00:00 UTC
  assignedByCoachId  String?
  createdAt          DateTime @default(now())

  player  Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  group   TeamGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  coach   Coach?    @relation(fields: [assignedByCoachId], references: [id], onDelete: SetNull)

  @@unique([playerId, weekStartDate])
}

model TrainingSession {
  id              String   @id @default(cuid())
  teamId          String
  groupId         String
  coachId         String
  type            String   @default("ice") // ice | ofp
  subType         String?  // optional: skating, strength, cardio, etc.
  startAt         DateTime
  endAt           DateTime
  locationName    String?
  locationAddress String?
  notes           String?
  status          String   @default("scheduled") // scheduled | cancelled | moved
  sessionStatus   String   @default("planned")   // planned | active | finished
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  team                 Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  group                TeamGroup             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  coach                Coach                 @relation(fields: [coachId], references: [id], onDelete: Restrict)
  trainingAttendances  TrainingAttendance[]
  playerSessionEvaluations PlayerSessionEvaluation[]
  playerSessionReports     PlayerSessionReport[]
  sessionReport            TrainingSessionReport?
}

model TrainingAttendance {
  id         String   @id @default(cuid())
  trainingId String
  playerId   String
  status     String // present | absent
  createdAt  DateTime @default(now())

  training TrainingSession @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  player   Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([trainingId, playerId])
}

model PlayerSessionEvaluation {
  id          String   @id @default(cuid())
  trainingId  String
  playerId    String
  effort      Int?
  focus       Int?
  discipline  Int?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  training TrainingSession @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  player   Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([trainingId, playerId])
}

// Общий отчёт тренера по тренировке (один на TrainingSession).
model TrainingSessionReport {
  id             String   @id @default(cuid())
  trainingId     String   @unique
  summary        String?
  focusAreas     String?
  coachNote      String?
  parentMessage  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  training TrainingSession @relation(fields: [trainingId], references: [id], onDelete: Cascade)
}

// Текстовый отчёт тренера по игроку на конкретной тренировке (TrainingSession).
model PlayerSessionReport {
  id            String   @id @default(cuid())
  trainingId    String
  playerId      String
  summary       String?
  focusAreas    String?
  coachNote     String?
  parentMessage String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  training TrainingSession @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  player   Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([trainingId, playerId])
}

model TeamFeedPost {
  id          String    @id @default(cuid())
  teamId      String
  authorId    String
  authorRole  String
  authorName  String
  type        String
  title       String
  body        String
  imageUrl    String?
  isPinned    Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Coach {
  id                         String   @id @default(cuid())
  firstName                  String
  lastName                   String
  phone                      String?
  email                      String?
  specialization             String?
  photoUrl                   String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  isMarketplaceIndependent   Boolean  @default(false)
  linkedUserId               String?  @unique
  linkedUser                 User?    @relation("UserMarketplaceCoach", fields: [linkedUserId], references: [id], onDelete: SetNull)
  displayName                String?
  city                       String?
  bio                        String?
  specialties                Json     @default("[]")
  formats                    Json     @default("[]")
  priceFrom                  Int?

  teams                Team[]
  coachRatings         CoachRating[]
  trainingJournal      TrainingJournal[]
  parentInvites        ParentInvite[]
  chatConversations    ChatConversation[]
  groupAssignments     PlayerGroupAssignment[]
  trainingSessions     TrainingSession[]
  coachAvailabilities  CoachAvailability[]
  marketplaceBookingRequests CoachBookingRequest[] @relation("IndependentCoachBookings")
  marketplaceSlotBookings    MarketplaceSlotBooking[]
}

model CoachAvailability {
  id        String   @id @default(cuid())
  coachId   String
  date      DateTime
  startTime String
  endTime   String
  price     Int
  type      String
  isBooked  Boolean  @default(false)
  createdAt DateTime @default(now())

  coach                Coach                   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  marketplaceBookings MarketplaceSlotBooking[]

  @@index([coachId, date])
}

model ChatConversation {
  id        String   @id @default(cuid())
  playerId  String
  parentId  String
  coachId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  player   Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  parent   Parent       @relation(fields: [parentId], references: [id], onDelete: Cascade)
  coach    Coach        @relation(fields: [coachId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@unique([playerId, parentId, coachId])
}

model ChatMessage {
  id             String    @id @default(cuid())
  conversationId String
  senderType     String    // "parent" | "coach"
  senderId       String
  text           String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model Training {
  id           String   @id @default(cuid())
  title        String
  startTime    DateTime
  endTime      DateTime
  location     String?
  teamId       String
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  team        Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  attendances Attendance[]
  journal     TrainingJournal[]
}

model Attendance {
  id         String           @id @default(cuid())
  trainingId String
  playerId   String
  status     AttendanceStatus
  comment    String?

  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([trainingId, playerId])
}

model Parent {
  id               String             @id @default(cuid())
  firstName        String
  lastName         String
  phone            String?            @unique
  email            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  pushToken        String?
  players          Player[]
  parentPlayers    ParentPlayer[]
  notifications    Notification[]
  messages         Message[]
  chatConversations ChatConversation[]
  pushDevices      PushDevice[]
}

model PushDevice {
  id             String    @id @default(cuid())
  parentId       String
  expoPushToken  String
  platform       String
  appVersion     String?
  isActive       Boolean   @default(true)
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([parentId, expoPushToken])
}

model ParentPlayer {
  id        String   @id @default(cuid())
  parentId  String
  playerId  String
  relation  String?
  createdAt DateTime @default(now())

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([parentId, playerId])
}

model ParentInvite {
  id               String    @id @default(cuid())
  phone            String
  playerId         String
  teamId           String?
  invitedByUserId  String
  invitedByCoachId String?
  status           String    @default("pending") // pending | accepted
  createdAt        DateTime  @default(now())
  acceptedAt       DateTime?

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  coach  Coach? @relation(fields: [invitedByCoachId], references: [id], onDelete: SetNull)
}

model Player {
  id                  String    @id @default(cuid())
  firstName           String
  lastName            String
  birthYear           Int
  birthDate           DateTime?
  position            String
  grip                String
  height              Int?
  weight              Int?
  photoUrl            String?
  city                String?
  country             String?
  internationalRating Int?
  teamId              String?
  parentId            String?
  status              String    @default("Активен")
  comment             String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  team          Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  parent        Parent?          @relation(fields: [parentId], references: [id], onDelete: SetNull)
  parentPlayers ParentPlayer[]
  parentInvites ParentInvite[]
  profile      PlayerProfile?   @relation()
  stats        PlayerStat[]
  notes        PlayerNote[]
  attendances  Attendance[]
  passport     Passport?
  teamHistory  TeamHistory[]
  medical      Medical?
  skills       Skills?
  achievements Achievement[]
  videos       Video[]
  videoAnalyses PlayerVideoAnalysis[]
  payments      PlayerPayment[]
  chatConversations ChatConversation[]
  coachRatings       CoachRating[]
  progressSnapshots  PlayerProgressSnapshot[]
  notifications Notification[]
  messages      Message[]
  aiAnalyses    AiAnalysis[]
  groupAssignments    PlayerGroupAssignment[]
  trainingAttendances TrainingAttendance[]
  playerSessionEvaluations PlayerSessionEvaluation[]
  playerSessionReports     PlayerSessionReport[]
}

model PlayerProgressSnapshot {
  id               String   @id @default(cuid())
  playerId         String
  month            Int
  year             Int
  games            Int     @default(0)
  goals            Int     @default(0)
  assists          Int     @default(0)
  points           Int     @default(0)
  attendancePercent Int?
  coachComment     String?
  focusArea        String?
  trend            String? // up | stable | down
  createdAt        DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, month, year])
}

model Passport {
  id              String   @id @default(cuid())
  playerId        String   @unique
  passportNumber  String
  issueDate       DateTime
  expiryDate      DateTime
  issuedBy        String
  internationalID String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model TeamHistory {
  id       String   @id @default(cuid())
  playerId String
  teamName String
  season   String
  league   String
  coach    String?
  stats    Json?
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Medical {
  id          String   @id @default(cuid())
  playerId    String   @unique
  lastCheckup DateTime?
  injuries    Json?
  restrictions String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Skills {
  id            String   @id @default(cuid())
  playerId      String   @unique
  speed         Int?
  shotAccuracy  Int?
  dribbling     Int?
  stamina       Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String   @id @default(cuid())
  playerId    String
  title       String
  year        Int
  description String?
  createdAt   DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Video {
  id       String   @id @default(cuid())
  playerId String
  title    String
  url      String
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model PlayerVideoAnalysis {
  id             String   @id @default(cuid())
  playerId       String
  videoUrl       String
  analysisText   String?
  strengths      Json     @default("[]") // string[]
  growthAreas    Json     @default("[]") // string[]
  recommendations Json   @default("[]") // string[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model PlayerProfile {
  id           String   @id @default(cuid())
  playerId     String   @unique
  height       Int?
  weight       Int?
  jerseyNumber Int?
  shoots       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model PlayerStat {
  id        String @id @default(cuid())
  playerId  String
  season    String
  games     Int    @default(0)
  goals     Int    @default(0)
  assists   Int    @default(0)
  points    Int    @default(0)
  pim       Int    @default(0)

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model AiAnalysis {
  id              String   @id @default(cuid())
  playerId        String
  summary         String
  strengths       Json     @default("[]") // string[]
  weaknesses      Json     @default("[]") // string[]
  recommendations Json     @default("[]") // string[]
  score           Float?
  createdAt       DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("ai_analyses")
}

model PlayerNote {
  id        String   @id @default(cuid())
  playerId  String
  note      String
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model PlayerPayment {
  id                   String    @id @default(cuid())
  playerId             String
  month                Int
  year                 Int
  amount               Int       @default(0)
  status               String    @default("Не оплачено")
  paidAt               DateTime?
  comment              String?
  stripePaymentIntentId String?
  stripeCustomerId     String?
  stripeCheckoutUrl    String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @default(now()) @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  TRAINING_NEW
  SCHEDULE_CHANGE
  PAYMENT_DUE
  PAYMENT_RECEIVED
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String?
  link      String?
  playerId  String?
  parentId  String?
  read      Boolean          @default(false)
  emailSent Boolean          @default(false)
  pushSent  Boolean          @default(false)
  createdAt DateTime         @default(now())

  player Player? @relation(fields: [playerId], references: [id], onDelete: Cascade)
  parent Parent? @relation(fields: [parentId], references: [id], onDelete: Cascade)
}

model CoachRating {
  id             String   @id @default(cuid())
  coachId        String
  playerId       String
  rating         Int
  recommendation String?
  comment        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  coach  Coach  @relation(fields: [coachId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model TrainingJournal {
  id          String   @id @default(cuid())
  trainingId  String
  coachId     String
  topic       String?
  goals       String?
  notes       String?
  teamComment String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  coach    Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([trainingId, coachId])
}

model Message {
  id        String   @id @default(cuid())
  parentId  String
  playerId  String
  fromParent Boolean @default(true)
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id         String   @id @default(cuid())
  type       String
  entityType String?
  entityId   String?
  message    String
  metadata   Json?
  createdAt  DateTime @default(now())
}

model CoachProfile {
  id              String   @id @default(cuid())
  fullName        String
  slug            String   @unique
  city            String
  bio             String?
  specialties     Json     // string[]
  experienceYears Int      @default(0)
  priceFrom       Int      @default(0)
  rating          Float?
  trainingFormats Json     // string[]
  photoUrl        String?
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  services  CoachService[]
  bookings  CoachBookingRequest[]
}

model CoachService {
  id              String   @id @default(cuid())
  coachId         String
  title           String
  category        String
  description     String?
  durationMinutes Int      @default(60)
  price           Int      @default(0)
  format          String
  createdAt       DateTime @default(now())

  coach CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
}

model CoachBookingRequest {
  id                   String    @id @default(cuid())
  coachId              String?
  independentCoachId   String?
  parentId             String?
  parentName           String
  parentPhone          String
  playerId             String?
  message              String
  preferredDate        DateTime?
  status               String    @default("new")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  coach             CoachProfile? @relation(fields: [coachId], references: [id], onDelete: Cascade)
  independentCoach  Coach?        @relation("IndependentCoachBookings", fields: [independentCoachId], references: [id], onDelete: Cascade)
}

// Marketplace reservation for CoachAvailability (independent coaches only).
model MarketplaceSlotBooking {
  id             String   @id @default(cuid())
  slotId         String
  coachId        String
  bookerUserId   String
  status         String   @default("pending")
  parentName     String
  parentPhone    String
  playerId       String?
  message        String?
  paymentStatus     String    @default("unpaid")
  paymentMethod     String?
  paidAt            DateTime?
  paymentReference  String?
  amountSnapshot    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  slot  CoachAvailability @relation(fields: [slotId], references: [id], onDelete: Cascade)
  coach Coach             @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@index([bookerUserId, createdAt])
  @@index([coachId, status])
}

model Subscription {
  id                 String   @id @default(cuid())
  parentId           String   @unique
  planCode           String
  status             String
  billingInterval    String
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  billingRecords SubscriptionBillingRecord[]
}

model SubscriptionBillingRecord {
  id             String   @id @default(cuid())
  parentId       String
  subscriptionId String?
  date           DateTime
  productName    String
  amount         Int
  currency       String
  status         String
  type           String
  createdAt      DateTime @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
}

// Coach mobile app — session sync from Session Capture
model CoachSession {
  id          String    @id @default(cuid())
  sessionId   String    @unique // Client or server: session_xxx / sess_xxx
  title       String
  startedAt   DateTime
  endedAt     DateTime? // null = active session
  teamId      String?   // For live session scoping
  coachUserId String?   // From auth; may be demo user id
  createdAt   DateTime  @default(now())

  observations CoachSessionObservation[]
  snapshots    CoachSessionPlayerSnapshot[]
  parentDrafts CoachSessionParentDraft[]
}

model CoachSessionObservation {
  id              String   @id @default(cuid())
  coachSessionId  String
  playerId        String
  playerName      String
  skillType       String
  impact          String   // positive | neutral | negative
  note            String?
  createdAtTs     DateTime // From payload (ms) → DateTime

  coachSession CoachSession @relation(fields: [coachSessionId], references: [id], onDelete: Cascade)
}

model CoachSessionPlayerSnapshot {
  id              String    @id @default(cuid())
  coachSessionId  String
  playerId        String
  skills          Json      // [{ skillType, score, trend, confidence }]
  lastUpdatedAt   DateTime?

  coachSession CoachSession @relation(fields: [coachSessionId], references: [id], onDelete: Cascade)
}

model CoachSessionParentDraft {
  id               String   @id @default(cuid())
  coachSessionId   String
  playerId         String
  playerName       String
  headline         String
  parentMessage    String
  positives        Json     // string[]
  improvementAreas Json     // string[]
  focusSkills      Json     // string[]

  coachSession CoachSession @relation(fields: [coachSessionId], references: [id], onDelete: Cascade)
}

/// Coach-created report text (voice / manual create flows)
model Report {
  id          String     @id @default(cuid())
  coachId     String
  playerId    String?
  title       String
  content     String
  createdAt   DateTime   @default(now())
  voiceNoteId String?
  voiceNote   VoiceNote? @relation(fields: [voiceNoteId], references: [id], onDelete: SetNull)
}

/// Coach-created action item (task / follow-up)
model ActionItem {
  id          String     @id @default(cuid())
  coachId     String
  playerId    String?
  title       String
  description String
  status      String     @default("open")
  createdAt   DateTime   @default(now())
  voiceNoteId String?
  voiceNote   VoiceNote? @relation(fields: [voiceNoteId], references: [id], onDelete: SetNull)
}

/// Coach-created parent message draft (standalone, not synced session draft)
model ParentDraft {
  id          String     @id @default(cuid())
  coachId     String
  playerId    String?
  text        String
  createdAt   DateTime   @default(now())
  voiceNoteId String?
  voiceNote   VoiceNote? @relation(fields: [voiceNoteId], references: [id], onDelete: SetNull)
}

/// Persisted coach voice notes (audio upload + STT transcript + lightweight analysis)
model VoiceNote {
  id             String   @id @default(cuid())
  coachId         String
  playerId        String?
  transcript      String
  summary         String?
  highlightsJson  Json?
  suggestionsJson Json?
  /// Client-side AI analysis snapshot (structured); not computed on server.
  analysisJson    Json?
  uploadId        String?
  audioFileName   String?
  audioMimeType   String?
  audioSizeBytes  Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reports       Report[]
  actionItems   ActionItem[]
  parentDrafts  ParentDraft[]

  @@unique([coachId, uploadId])
}

