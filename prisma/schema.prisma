  createdAt         DateTime         @default(now())
  updatedAt         DateTime @updatedAt
  createdByUserId   String?
  createdByCoachId  String?
  Coach             Coach?           @relation(fields: [createdByCoachId], references: [id])
  User              User?            @relation(fields: [createdByUserId], references: [id])
  Player            Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  TrainingSession   TrainingSession? @relation(fields: [trainingSessionId], references: [id])

  @@index([playerId, measuredAt])
  @@index([trainingSessionId])
}

model ParentTeamAnnouncementRead {
  id         String    @id @default(cuid())
  parentId   String
  teamId     String
  lastReadAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  Parent     Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  Team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([parentId, teamId])
}

model PlayerIndex {
  id            String   @id @default(cuid())
  playerId      String
  attackIndex   Decimal? @db.Decimal(6, 3)
  defenseIndex  Decimal? @db.Decimal(6, 3)
  skatingIndex  Decimal? @db.Decimal(6, 3)
  iqIndex       Decimal? @db.Decimal(6, 3)
  physicalIndex Decimal? @db.Decimal(6, 3)
  overallIndex  Decimal? @db.Decimal(6, 3)
  calculatedAt  DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  Player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, calculatedAt])
}

model PlayerSessionStructuredMetrics {
  id                String          @id @default(cuid())
  trainingSessionId String
  playerId          String
  schemaVersion     Int             @default(1)
  source            StatsSource     @default(MANUAL)
  iceTechnical      Json?
  tactical          Json?
  ofpQualitative    Json?
  physical          Json?
  behavioral        Json?
  observation       Json?
  voiceMeta         Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime @updatedAt
  Player            Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  TrainingSession   TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)

  @@unique([trainingSessionId, playerId])
  @@index([playerId, updatedAt])
}

model PlayerStatsSnapshot {
  id            String             @id @default(cuid())
  playerId      String
  periodType    SnapshotPeriodType
  periodStart   DateTime
  periodEnd     DateTime
  goals         Int?
  assists       Int?
  shots         Int?
  takeaways     Int?
  turnovers     Int?
  passSuccess   Int?
  passFail      Int?
  attackIndex   Decimal?           @db.Decimal(6, 3)
  defenseIndex  Decimal?           @db.Decimal(6, 3)
  skatingIndex  Decimal?           @db.Decimal(6, 3)
  physicalIndex Decimal?           @db.Decimal(6, 3)
  overallIndex  Decimal?           @db.Decimal(6, 3)
  summary       String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime @updatedAt
  Player        Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([periodStart, periodEnd])
  @@index([playerId, periodStart])
  @@index([playerId, periodType, periodStart])
}

model PlayerTrainingReport {
  id                String               @id @default(cuid())
  playerId          String
  trainingSessionId String
  rawText           String?
  summary           String?
  coachNote         String?
  status            TrainingReportStatus @default(DRAFT)
  source            StatsSource
  audioUrl          String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime @updatedAt
  createdByUserId   String?
  createdByCoachId  String?
  Coach             Coach?               @relation(fields: [createdByCoachId], references: [id])
  User              User?                @relation(fields: [createdByUserId], references: [id])
  Player            Player               @relation(fields: [playerId], references: [id], onDelete: Cascade)
  TrainingSession   TrainingSession      @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)

  @@index([playerId, trainingSessionId])
  @@index([trainingSessionId])
}

model SkillProgress {
  id               String         @id @default(cuid())
  playerId         String
  skill            SkillType
  status           SkillStatus
  trend            TrendDirection
  note             String?
  measuredAt       DateTime
  createdAt        DateTime       @default(now())
  updatedAt        DateTime @updatedAt
  createdByUserId  String?
  createdByCoachId String?
  Coach            Coach?         @relation(fields: [createdByCoachId], references: [id])
  User             User?          @relation(fields: [createdByUserId], references: [id])
  Player           Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, measuredAt])
  @@index([playerId, skill, measuredAt])
}

model TrainingSessionCoachJournal {
  id                String          @id @default(cuid())
  trainingSessionId String
  coachId           String
  topic             String?
  goals             String?
  notes             String?
  teamComment       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime @updatedAt
  Coach             Coach           @relation(fields: [coachId], references: [id], onDelete: Cascade)
  TrainingSession   TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)

  @@unique([trainingSessionId, coachId])
  @@index([coachId])
}

