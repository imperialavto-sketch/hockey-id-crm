{
  "name": "hockey-id-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "clean:next": "rm -rf .next",
    "dev:clean": "npm run clean:next && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "verify": "npm run build && npm run lint",
    "typecheck:coach": "cd coach-app && npx tsc --noEmit",
    "typecheck:parent": "cd parent-app && npx tsc --noEmit",
    "verify:apps": "npm run typecheck:coach && npm run typecheck:parent",
    "verify:deep": "npm run verify && npm run verify:apps && npm run test:live-training-parse && npm run test:arena-core-facts && npm run test:arena-core-bindings && npm run test:parent-summary-supercore-pilot && npm run test:supercore-action-candidates-merge && npm run test:arena-supercore-actions && npm run test:arena-crm-supercore-operational-focus && npm run test:arena-crm-wire-classifier && npm run test:arena-planned-vs-observed-continuity && npm run test:group-context-live-session && npm run test:parent-facing-trust-wording-slice && npm run test:production-contract-guards",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:pilot": "npx tsx prisma/seed-pilot-smoke.ts",
    "smoke:pilot:live": "npx tsx scripts/pilot-smoke-live-publish.ts",
    "db:seed:demo": "npx tsx prisma/seed.ts",
    "db:seed:login-recovery": "npx tsx prisma/seed-login-recovery.ts",
    "db:reset:user": "npx tsx prisma/seed-single-user.ts",
    "db:seed:full": "node scripts/seed-full.js",
    "db:seed:settings": "node scripts/seed-settings.js",
    "scrape:players": "node scripts/scrapePlayers.js",
    "db:migrate": "prisma migrate dev",
    "ip": "bash scripts/print-ip.sh",
    "set-local-ip": "node scripts/set-local-ip.js",
    "dev:coach": "npm run set-local-ip && cd coach-app && npx expo start --clear",
    "dev:parent": "npm run set-local-ip && cd parent-app && npx expo start --clear",
    "qa:marketplace-payment": "npx tsx scripts/marketplace-booking-payment-check.ts",
    "qa:prod": "npx tsx scripts/prod-check.ts",
    "auth:audit-passwords": "npx tsx scripts/audit-user-passwords.ts",
    "test:live-training-parse": "npx tsx src/lib/live-training/parse-live-training-text.selftest.ts",
    "test:arena-core-facts": "npx tsx src/lib/arena/supercore/load-arena-core-facts.selftest.ts",
    "test:arena-core-bindings": "npx tsx src/lib/arena/supercore/build-arena-core-bindings.selftest.ts",
    "test:parent-summary-supercore-pilot": "npx tsx src/lib/live-training/parent-latest-summary-arena-supercore.normalize.selftest.ts",
    "test:supercore-action-candidates-merge": "npx tsx src/lib/arena/supercore/merge-supercore-focus-decisions-into-action-candidates.selftest.ts",
    "test:arena-supercore-actions": "npx tsx src/lib/arena/supercore/actions.selftest.ts",
    "test:arena-crm-supercore-operational-focus": "npx tsx src/lib/arena/crm/arena-crm-supercore-operational-focus.selftest.ts",
    "test:arena-crm-wire-classifier": "npx tsx src/lib/arena/crm/arena-crm-wire-classifier.selftest.ts",
    "test:arena-planned-vs-observed-continuity": "npx tsx src/lib/live-training/arena-planned-vs-observed-continuity.selftest.ts",
    "test:group-context-live-session": "npx tsx src/lib/live-training/group-context-live-session.selftest.ts",
    "test:parent-facing-trust-wording-slice": "npx tsx src/lib/arena/parent-facing-trust-wording-slice.selftest.ts && (cd parent-app && npx tsx lib/arenaWeeklyInsight.selftest.ts)",
    "test:production-contract-guards": "npx tsx src/lib/contract/production-contract-repair-guards.selftest.ts"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.454.0",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "stripe": "^20.4.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.4.15"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
