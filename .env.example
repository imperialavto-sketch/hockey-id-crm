DATABASE_URL="postgresql://user:password@localhost:5432/hockey_crm?schema=public"

# Stripe (оплаты)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=Hockey ID <noreply@hockey-id.ru>

# AI анализ (OpenAI) — для AI видео-анализа и паспорта игрока
OPENAI_API_KEY=sk-xxx

# Push (опционально)
FIREBASE_SERVER_KEY=
VAPID_PUBLIC_KEY=

# Demo auth for /api/auth/login (dev only).
# DO NOT enable in public production rollout.
# DEMO_AUTH_ENABLED=false

# Parent email self-registration (/api/auth/register). Set true to force phone-only onboarding.
# PARENT_EMAIL_REGISTER_DISABLED=false

# Debug: bypass Prisma for parent mobile API (return mock immediately to test reachability)
# DO NOT enable in production.
# PARENT_API_USE_MOCK=1

# Legacy Training / Attendance HTTP writes (`PATCH|DELETE /api/legacy/trainings/[id]`, attendance POST).
# Unset or true = writes allowed (default). false / 0 / no = 403 before Prisma (runtime verification / staged disable).
# LEGACY_TRAINING_HTTP_WRITES_ENABLED=true
