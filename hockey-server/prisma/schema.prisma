generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Parent {
  id        Int      @id @default(autoincrement())
  email     String?  @unique
  password  String?
  phone     String?  @unique
  firstName String?
  lastName  String?
  createdAt DateTime @default(now())

  players                Player[]
  authCodes              ParentAuthCode[]
  subscriptions          Subscription[]
  billingRecords         SubscriptionBillingRecord[]
  bookingRequests        BookingRequest[]
  coachMarkConversation  CoachMarkConversation?
}

model ParentAuthCode {
  id        Int      @id @default(autoincrement())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  parentId Int?
  parent   Parent? @relation(fields: [parentId], references: [id], onDelete: SetNull)
}

model Coach {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?  @unique
  createdAt DateTime @default(now())

  teams     Team[]
}

model CoachProfile {
  id               Int      @id @default(autoincrement())
  fullName         String
  slug             String   @unique
  city             String
  bio              String?
  specialization   String?
  specialties      Json?    // string[]
  experienceYears  Int      @default(0)
  priceFrom        Int      @default(0)
  rating           Float?
  photoUrl         String?
  avatar           String?
  description      String?
  isPublished      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  services   CoachService[]
  slots       CoachSlot[]
  bookings   BookingRequest[]
}

model CoachService {
  id              Int      @id @default(autoincrement())
  coachId         Int
  title           String
  category        String
  durationMinutes Int      @default(60)
  price           Int      @default(0)
  format          String
  createdAt       DateTime @default(now())

  coach CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
}

model CoachSlot {
  id         Int      @id @default(autoincrement())
  coachId    Int
  startTime  DateTime
  endTime    DateTime
  available  Boolean  @default(true)
  createdAt  DateTime @default(now())

  coach CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
}

model BookingRequest {
  id            Int      @id @default(autoincrement())
  coachId       Int
  parentId      Int?
  parentName    String?
  parentPhone   String?
  playerId      Int?
  message       String?
  preferredDate DateTime?
  status        String   @default("new")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  coach CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  parent Parent?      @relation(fields: [parentId], references: [id], onDelete: SetNull)
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  ageGroup  String?
  createdAt DateTime @default(now())

  coachId   Int?
  coach     Coach?   @relation(fields: [coachId], references: [id])

  players   Player[]
  schedules Schedule[]
}

model Player {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  birthYear Int
  position  String?
  avatarUrl String?
  createdAt DateTime @default(now())

  parentId  Int
  parent    Parent   @relation(fields: [parentId], references: [id])

  teamId    Int?
  team      Team?    @relation(fields: [teamId], references: [id])

  stats         PlayerStats[]
  videoAnalyses VideoAnalysis[]
  aiAnalyses    AIAnalysis[]
}

model PlayerStats {
  id        Int      @id @default(autoincrement())
  goals     Int      @default(0)
  assists   Int      @default(0)
  games     Int      @default(0)
  createdAt DateTime @default(now())

  playerId  Int
  player    Player   @relation(fields: [playerId], references: [id])
}

model Schedule {
  id        Int      @id @default(autoincrement())
  title     String
  date      DateTime
  location  String?
  createdAt DateTime @default(now())

  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id])
}

model VideoAnalysis {
  id        Int      @id @default(autoincrement())
  videoUrl  String
  result    Json?
  createdAt DateTime @default(now())

  playerId  Int
  player    Player   @relation(fields: [playerId], references: [id])
}

model AIAnalysis {
  id        Int      @id @default(autoincrement())
  report    String
  score     Float?
  createdAt DateTime @default(now())

  playerId  Int
  player    Player   @relation(fields: [playerId], references: [id])
}

model Subscription {
  id                 Int      @id @default(autoincrement())
  parentId           Int      @unique
  planCode           String
  status             String
  billingInterval    String
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  parent  Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  records SubscriptionBillingRecord[]
}

model SubscriptionBillingRecord {
  id             Int      @id @default(autoincrement())
  parentId       Int
  subscriptionId Int?
  date           DateTime
  productName    String
  amount         Int
  currency       String
  status         String
  type           String
  createdAt      DateTime @default(now())

  parent       Parent        @relation(fields: [parentId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
}

model CoachMarkConversation {
  id        Int      @id @default(autoincrement())
  parentId  Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Parent              @relation(fields: [parentId], references: [id], onDelete: Cascade)
  messages CoachMarkMessage[]
}

model CoachMarkMessage {
  id             Int      @id @default(autoincrement())
  conversationId Int
  senderType     String
  senderId       String
  text           String   @db.Text
  isAI           Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation CoachMarkConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}
