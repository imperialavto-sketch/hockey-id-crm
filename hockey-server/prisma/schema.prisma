generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Parent {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  players   Player[]
}

model Coach {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?  @unique
  createdAt DateTime @default(now())

  teams     Team[]
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  ageGroup  String?
  createdAt DateTime @default(now())

  coachId   Int?
  coach     Coach?   @relation(fields: [coachId], references: [id])

  players   Player[]
  schedules Schedule[]
}

model Player {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  birthYear Int
  position  String?
  createdAt DateTime @default(now())

  parentId  Int
  parent    Parent   @relation(fields: [parentId], references: [id])

  teamId    Int?
  team      Team?    @relation(fields: [teamId], references: [id])

  stats         PlayerStats[]
  videoAnalyses VideoAnalysis[]
  aiAnalyses    AIAnalysis[]
}

model PlayerStats {
  id        Int      @id @default(autoincrement())
  goals     Int      @default(0)
  assists   Int      @default(0)
  games     Int      @default(0)
  createdAt DateTime @default(now())

  playerId  Int
  player    Player   @relation(fields: [playerId], references: [id])
}

model Schedule {
  id        Int      @id @default(autoincrement())
  title     String
  date      DateTime
  location  String?
  createdAt DateTime @default(now())

  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id])
}

model VideoAnalysis {
  id        Int      @id @default(autoincrement())
  videoUrl  String
  result    Json?
  createdAt DateTime @default(now())

  playerId  Int
  player    Player   @relation(fields: [playerId], references: [id])
}

model AIAnalysis {
  id        Int      @id @default(autoincrement())
  report    String
  score     Float?
  createdAt DateTime @default(now())

  playerId  Int
  player    Player   @relation(fields: [playerId], references: [id])
}
